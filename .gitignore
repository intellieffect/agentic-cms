editor/.removed_files/
editor/.vercel/
editor/.DS_Store
editor/~/
# ↑ 마지막은 literal "~" 디렉토리 — tilde expansion 실패로 생기는 오류 경로 차단
editor/tsconfig.tsbuildinfo
editor/**/tsconfig.tsbuildinfo
editor/.turbo/
editor/coverage/

