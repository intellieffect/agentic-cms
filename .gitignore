# editor/ — Python FastAPI 영상 편집 서버 (embedded)
# editor/.gitignore 도 개별 패턴을 갖고 있지만, top-level 에서도 중복 방어.
editor/.venv/
editor/__pycache__/
editor/**/__pycache__/
