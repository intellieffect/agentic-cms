# ============================================================
# agentic-cms MCP 서버 — 환경변수 템플릿
# ============================================================
# 실제 값으로 채워서 `.env` 로 저장. Claude Code (또는 다른 MCP client) 가
# 이 값을 읽어 Supabase / dashboard / editor / Postiz 에 접속.
# multi-tenant 배포: 고객마다 이 파일을 각자의 값으로 교체.
# ============================================================

# ── Supabase (필수) ─────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Dashboard 연동 (뉴스레터 발송 MCP 도구용) ──────────────
# send_newsletter 가 dashboard 의 /api/newsletter/send 로 HTTP 호출.
DASHBOARD_API_URL=http://127.0.0.1:3003
# Optional — dashboard/.env.local 의 DASHBOARD_MCP_SECRET 과 동일 값이면 인증.
DASHBOARD_MCP_SECRET=your-random-32-byte-hex-secret

# ── Editor API 연동 (영상 편집 도구용) ──────────────────────
EDITOR_API_URL=http://127.0.0.1:8092

# ── content-core CLI (Markdown → PlateJS 변환) ──────────────
# create_blog_post_from_markdown 도구가 호출.
CONTENT_CORE_CLI_PATH=/absolute/path/to/content-core/dist/cli.js
# (선택) CLI 실행 timeout, 기본 30000 ms. 대용량 Markdown 변환 시 늘리기.
# CONTENT_CORE_CLI_TIMEOUT_MS=30000

# ── Tenant branding (multi-tenant 핵심 env) ─────────────────
# Blog meta_title suffix — 예: META_TITLE_SUFFIX="YourBrand" → "{title} | YourBrand"
# 미설정 시 suffix 없이 title 만 사용.
META_TITLE_SUFFIX=

# ── Postiz 소셜 발행 (선택) ─────────────────────────────────
# Postiz 인스턴스 URL + API key. 없으면 send_to_postiz 도구 비활성.
POSTIZ_API_URL=https://postiz.your-domain.com
POSTIZ_API_KEY=
# 인증 방식: raw (기본) | bearer | x-api-key — Postiz 배포 버전에 따라
POSTIZ_AUTH_SCHEME=raw
