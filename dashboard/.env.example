# ============================================================
# agentic-cms dashboard — 환경변수 템플릿
# ============================================================
# 실제 값으로 채워서 `.env.local` 로 저장 후 사용.
# multi-tenant 배포: 고객마다 이 파일을 각자의 값으로 교체만 하면 됨.
# ============================================================

# ── Supabase (필수) ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Editor API (영상 편집 Python 서버 — agentic-cms/editor 서브디렉토리) ──
NEXT_PUBLIC_EDITOR_API_URL=http://localhost:8092
EDITOR_API_DIR=/absolute/path/to/agentic-cms/editor
# (선택) editor 를 다른 포트에서 기동하고 싶으면
# EDITOR_API_PORT=8092

# ── Video 미디어 경로 (선택 — editor proxy 쓸 때 override) ────
# 기본값 있음 — 지정 안 해도 정상 동작.
# NEXT_PUBLIC_MEDIA_PROXY_PREFIX=/_proxy
# NEXT_PUBLIC_MEDIA_ROOT=
# NEXT_PUBLIC_MEDIA_FINISHED=
# NEXT_PUBLIC_MEDIA_DEFAULT_SOURCE=

# ── Tenant branding (multi-tenant 핵심 env — 고객마다 값 다름) ─────
# 사이트 URL — 뉴스레터 발송 링크, 썸네일 prefix, GSC 등에 사용 (필수)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# GSC (Google Search Console) 분석 대상 URL — 다르면 override, 없으면 SITE_URL 로 fallback
# NEXT_PUBLIC_GSC_SITE_URL=https://your-domain.com

# 브랜드명 — 뉴스레터 헤더, meta_title suffix 등에 노출 (선택)
NEXT_PUBLIC_BRAND_NAME=Your Brand

# 고객 CTA 정보 — 캐러셀 CTA 슬라이드 default 에 주입 (선택)
NEXT_PUBLIC_CONTACT_EMAIL=contact@your-domain.com
NEXT_PUBLIC_CONTACT_DOMAIN=your-domain.com

# Analytics self-referrer whitelist — 자사 도메인 여러개 쉼표로 구분 (선택)
ANALYTICS_OWN_DOMAINS=your-domain.com,studio.your-domain.com

# Vercel preview URL 키워드 (*.vercel.app 중 자사 프로젝트 식별, 쉼표 구분)
ANALYTICS_VERCEL_KEYWORDS=your-project,another-project

# 뉴스레터 발신인 — 필수 (Resend 사용 시). 형식: "Display Name <address@domain>"
NEWSLETTER_FROM=Your Brand <newsletter@your-domain.com>

# 캐러셀 브랜드 (선택) — 슬라이드 워터마크/핸들/아바타에 노출
NEXT_PUBLIC_BRAND_HANDLE=@your-brand
NEXT_PUBLIC_BRAND_EMOJI=🦞
# 아바타 이미지 — public/ 상대경로 또는 절대 URL (선택)
# NEXT_PUBLIC_BRAND_AVATAR_URL=/your-avatar.png

# ── GA4 / GSC Analytics (선택) ───────────────────────────────
# 서비스 계정 키 JSON 전체를 한 줄로. private_key 안의 실제 개행은 \n 으로 escape 필요.
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"..."}

# ── Newsletter (Resend) ─────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key

# ── MCP → Dashboard 인증 (선택) ─────────────────────────────
# send_newsletter MCP 도구가 외부에서 호출될 때 이 값으로 인증.
# agentic-cms/.env 의 DASHBOARD_MCP_SECRET 과 동일 값이어야 함.
DASHBOARD_MCP_SECRET=your-random-32-byte-hex-secret
