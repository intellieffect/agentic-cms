{
  "name": "@brxce/agentic-cms-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,editor -c cyan,yellow \"next dev\" \"npm run dev:editor 2>/dev/null || true\"",
    "dev:next": "next dev",
    "dev:editor": "node -e \"require('dotenv').config({path:'.env.local'});const d=process.env.EDITOR_API_DIR;if(!d){console.log('[editor-api] EDITOR_API_DIR not set');process.exit(0)}const{execSync}=require('child_process');execSync('cd '+d+' && .venv/bin/python -m src.server.app',{stdio:'inherit'})\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
